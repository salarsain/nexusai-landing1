PORT=5000
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1h

# Optional: enables real AI-generated task insights on the Dashboard.
# Get a free key at https://console.groq.com/keys — without it, the
# /api/ai/insights endpoint still works but falls back to a simple
# rule-based summary instead of an LLM-generated one.
GROQ_API_KEY=

# Comma-separated list of frontend origins allowed to call this API.
# Local dev default (localhost:5173) is used automatically if unset.
# In production set this to your Vercel URL, e.g.:
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=

# Only needed if you want the SQLite file somewhere other than server/db/tasks.db
# On Railway, point this at a mounted persistent volume, e.g. /data/tasks.db
DB_PATH=
